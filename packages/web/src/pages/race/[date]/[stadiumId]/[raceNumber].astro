---
import type {
  PredictorPrediction,
  RacePrediction,
  SeriesBetPayoutAggregate,
} from "@fun-site/shared";
import { getRaceGradeBadge, getStadiumById, parseRaceCode } from "@fun-site/shared";
import PredictorCard from "../../../../components/PredictorCard.astro";
import RacePreviewSection from "../../../../components/RacePreviewSection.astro";
import RacerTable from "../../../../components/RacerTable.astro";
import RaceResultSection from "../../../../components/RaceResultSection.astro";
import RecentFormSection from "../../../../components/RecentFormSection.astro";
import StadiumSeriesSummary from "../../../../components/StadiumSeriesSummary.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { loadAvailableDates, loadPredictions, loadSeriesSummary } from "../../../../lib/data";

/** レース番号リンクバー用の各レースのメタ情報 */
type RaceNavItem = {
  raceNumber: number;
  raceName: string;
  votingDeadline: string;
  isConfirmed: boolean;
  /** A君（slot=1, primary predictor）の直前買い目が的中したか。🎯 アイコン表示用。 */
  aRealtimeHit: boolean;
  /** 副予想者（実験スロット）の直前買い目が的中したか。🔥 アイコン表示用。存在しない場合は false。
   *  現行はモーター予想（slot=4）。過去日は退役済みのモーター評価変更予想（slot=2）を拾う。 */
  bRealtimeHit: boolean;
};

export async function getStaticPaths() {
  const dates = await loadAvailableDates();
  // 節集計は当日基準で 1 ファイルにまとまっているので、全パス共通で 1 度だけ読む。
  // summary.raceDate と一致する日のパスにのみ付与する (BUILD_ALL_DATES=1 で過去日を巻き込んでも
  // 古い日付の race ページに当日サマリーが漏れないようにするため)。
  const seriesSummary = await loadSeriesSummary();
  const paths = [];

  for (const date of dates) {
    const predictions = await loadPredictions(date);
    // (date, stadiumId) ごとにレースメタ情報を集約
    const racesByStadium = new Map<string, RaceNavItem[]>();
    for (const prediction of predictions) {
      const parsed = parseRaceCode(prediction.raceCode);
      const list = racesByStadium.get(parsed.stadiumId) ?? [];
      // 確定判定: realtime 結果がセットされていれば確定。
      // ただし結果 CSV が未取得でも votingDeadline が "確定" になっているケースがあるため、
      // 文字列も併用判定する (上流 CSV の `電話投票締切予定` 列は確定後に "確定" に置き換わる)。
      const isConfirmed =
        prediction.raceResult !== undefined || prediction.votingDeadline === "確定";
      // primary (slot=1) / 副予想者 (実験スロット) ぶんの直前買い目的中。
      // 新スキーマでは predictions[] が slot 昇順で並ぶ。
      // 旧 JSON (predictions 未設定) では legacy `betHitStatus` を primary ぶんとして採用、副予想者は無し扱い。
      // 副予想者は現行がモーター予想 (slot=4)。過去日には退役済みの
      // モーター評価変更予想 (slot=2) が入るため、slot=4 → slot=2 の順にフォールバックする。
      const predictorsBySlot = new Map(
        (prediction.predictions ?? []).map((p) => [p.slot, p] as const),
      );
      const aPred = predictorsBySlot.get(1);
      const bPred = predictorsBySlot.get(4) ?? predictorsBySlot.get(2);
      const aRealtimeHit =
        aPred?.betHitStatus.realtimeHit ?? prediction.betHitStatus?.realtimeHit ?? false;
      const bRealtimeHit = bPred?.betHitStatus.realtimeHit ?? false;
      list.push({
        raceNumber: prediction.raceNumber,
        raceName: prediction.raceName ?? "",
        votingDeadline: prediction.votingDeadline ?? "",
        isConfirmed,
        aRealtimeHit,
        bRealtimeHit,
      });
      racesByStadium.set(parsed.stadiumId, list);
    }
    for (const prediction of predictions) {
      const parsed = parseRaceCode(prediction.raceCode);
      const stadiumRaces = [
        ...(racesByStadium.get(parsed.stadiumId) ?? []),
      ].sort((a, b) => a.raceNumber - b.raceNumber);
      // 節集計は summary.raceDate と当該パスの date が一致するときだけ付与。
      const seriesAggregate =
        seriesSummary && seriesSummary.raceDate === parsed.date
          ? (seriesSummary.byStadium[parsed.stadiumId] ?? null)
          : null;
      paths.push({
        params: {
          date: parsed.date,
          stadiumId: parsed.stadiumId,
          raceNumber: String(prediction.raceNumber),
        },
        props: { prediction, stadiumRaces, seriesAggregate },
      });
    }
  }

  return paths;
}

interface Props {
  prediction: RacePrediction;
  stadiumRaces: RaceNavItem[];
  seriesAggregate: SeriesBetPayoutAggregate | null;
}

const { prediction, stadiumRaces, seriesAggregate } = Astro.props;
const stadium = getStadiumById(prediction.stadiumId);
const stadiumName = stadium?.name ?? prediction.stadiumName;
const title = `${stadiumName} ${prediction.raceNumber}R - ${prediction.raceName || "スタート予想"}`;
const raceByNumber = new Map(stadiumRaces.map((r) => [r.raceNumber, r]));
const headerGradeBadge = getRaceGradeBadge(prediction.grade ?? "");
---

<BaseLayout title={title}>
  {/* パンくず */}
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">トップ</a>
    <span class="mx-1">/</span>
    <a href={`/stadium/${prediction.stadiumId}/`} class="hover:text-blue-600">{stadiumName}</a>
    <span class="mx-1">/</span>
    <span>{prediction.raceNumber}R</span>
  </nav>

  {/* レース番号リンク (1R-12R) */}
  <nav class="bg-white rounded-lg shadow-sm p-2 mb-4 overflow-x-auto" aria-label="レース番号">
    <ul class="flex gap-1 min-w-max">
      {Array.from({ length: 12 }, (_, i) => i + 1).map((n) => {
        const isCurrent = n === prediction.raceNumber;
        const meta = raceByNumber.get(n);
        const isAvailable = meta !== undefined;
        const isConfirmed = meta?.isConfirmed ?? false;
        const aRealtimeHit = meta?.aRealtimeHit ?? false;
        const bRealtimeHit = meta?.bRealtimeHit ?? false;
        const hasAnyHit = aRealtimeHit || bRealtimeHit;

        // 状態別のスタイル: 背景色そのもので識別
        // 現在     → 青ベタ (白文字)
        // 開催予定 → 青系 (薄青背景 + 青ボーダー + 青文字)
        // 確定済み → 緑系 (薄緑背景 + 緑ボーダー + 緑文字)
        // 非開催   → 灰色ベタ (淡色文字)
        const tileBase =
          "flex flex-col items-center justify-between w-[4.75rem] min-h-[4.75rem] px-1 py-1.5 rounded-md select-none border-2";
        let tileClass = "";
        if (isCurrent) {
          tileClass = `${tileBase} bg-blue-600 text-white border-blue-700 shadow-sm`;
        } else if (!isAvailable) {
          tileClass = `${tileBase} bg-gray-100 text-gray-400 border-gray-200 cursor-not-allowed`;
        } else if (isConfirmed) {
          tileClass = `${tileBase} bg-emerald-50 text-emerald-900 border-emerald-300 hover:bg-emerald-100`;
        } else {
          tileClass = `${tileBase} bg-sky-50 text-sky-900 border-sky-300 hover:bg-sky-100`;
        }

        // 中身: レース番号 / レース名 / 締切 or 確定
        const inner = (
          <>
            <span class="text-sm font-bold leading-none tabular-nums">{n}R</span>
            <span class={`block text-[10px] leading-tight text-center mt-1 truncate max-w-full ${
              isCurrent
                ? "text-blue-100"
                : !isAvailable
                  ? "text-gray-400"
                  : isConfirmed
                    ? "text-emerald-700"
                    : "text-sky-700"
            }`}>
              {meta?.raceName || (isAvailable ? "—" : "未開催")}
            </span>
            {isAvailable ? (
              isConfirmed ? (
                <span class="mt-1 inline-flex items-center gap-0.5">
                  <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none ${
                    isCurrent ? "bg-white/25 text-white" : "bg-emerald-600 text-white"
                  }`}>
                    確定
                  </span>
                  {/* 本命予想の直前買い目的中 → 🎯 (amber)、モーター予想の直前買い目的中 → 🔥 (cyan)。両方的中時は両方表示。 */}
                  {aRealtimeHit && (
                    <span
                      class="inline-block text-[12px] leading-none"
                      title="本命予想の直前買い目が的中"
                      aria-label="本命予想の直前買い目が的中"
                    >
                      🎯
                    </span>
                  )}
                  {bRealtimeHit && (
                    <span
                      class="inline-block text-[12px] leading-none"
                      title="モーター予想の直前買い目が的中"
                      aria-label="モーター予想の直前買い目が的中"
                    >
                      🔥
                    </span>
                  )}
                </span>
              ) : (
                <span class={`mt-1 inline-block px-1 py-0.5 rounded text-[10px] font-mono leading-none tabular-nums ${
                  isCurrent ? "bg-white/15 text-white" : "bg-white text-sky-800 border border-sky-200"
                }`}>
                  {meta?.votingDeadline ? meta.votingDeadline : "—"}
                </span>
              )
            ) : (
              <span class="mt-1 text-[10px] leading-none">—</span>
            )}
          </>
        );

        if (isCurrent) {
          return (
            <li>
              <span class={tileClass} aria-current="page">
                {inner}
              </span>
            </li>
          );
        }
        if (isAvailable) {
          return (
            <li>
              <a
                href={`/race/${prediction.raceDate}/${prediction.stadiumId}/${n}/`}
                class={tileClass}
                aria-label={`${n}R ${meta?.raceName ?? ""}${
                  isConfirmed ? " 確定" : meta?.votingDeadline ? ` 締切 ${meta.votingDeadline}` : ""
                }${hasAnyHit ? ` (${[aRealtimeHit ? "本命予想の直前買い目的中" : "", bRealtimeHit ? "モーター予想の直前買い目的中" : ""].filter(Boolean).join(" / ")})` : ""}`}
              >
                {inner}
              </a>
            </li>
          );
        }
        return (
          <li>
            <span class={tileClass}>{inner}</span>
          </li>
        );
      })}
    </ul>
  </nav>

  {/* 今節成績（会場・primary predictor 直前買い目戦略の的中率 / 回収率）。
       1R-12R リンクバーの直下に置き、当該節での会場全体の傾向を最初に提示する。
       データが無い場合 (節初日で confirm 0 / summary 未生成) は何も描画しない。 */}
  <StadiumSeriesSummary agg={seriesAggregate} />

  {/* ヘッダ */}
  <header class="mb-6">
    <h1 class="text-2xl font-bold flex items-baseline gap-2 flex-wrap">
      <span>{stadiumName}</span>
      <span class="text-blue-600">{prediction.raceNumber}R</span>
      {prediction.raceName && (
        <span class="text-base text-gray-700 font-normal">{prediction.raceName}</span>
      )}
    </h1>
    <p class="text-sm text-gray-500 mt-1 flex flex-wrap items-center gap-x-2 gap-y-1">
      <span>{prediction.raceDate}</span>
      {headerGradeBadge && (
        <span
          class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none ${headerGradeBadge.tailwindClass}`}
          aria-label={`グレード ${headerGradeBadge.label}`}
        >
          {headerGradeBadge.label}
        </span>
      )}
      {prediction.raceTitle && <span>{prediction.raceTitle}</span>}
      {prediction.dayLabel && <span>{prediction.dayLabel}</span>}
      {prediction.votingDeadline && (
        <span>{prediction.votingDeadline === "確定" ? "確定" : `締切 ${prediction.votingDeadline}`}</span>
      )}
    </p>
  </header>

  {/* レース結果（確定済みのみ表示） */}
  {prediction.raceResult && (
    <section class="bg-white rounded-lg shadow-sm p-4 mb-6 border-l-4 border-blue-500">
      <h2 class="font-bold text-lg mb-3">レース結果</h2>
      <RaceResultSection
        result={prediction.raceResult}
        hitStatus={prediction.betHitStatus}
        predictorName={prediction.predictions?.[0]?.predictorName ?? "本命予想"}
      />
    </section>
  )}

  {/* 予想者ごとの買い目・回収率・AI 評価 */}
  {(() => {
    // 新スキーマで predictions[] が存在すればそれを使う。
    // 旧 JSON (predictions 未設定) では aiEvaluation 単体から仮想 PredictorPrediction
    // を 1 件だけ組み立て (= 本命予想相当) して同じ UI を流用する。
    const fromArray: readonly PredictorPrediction[] = prediction.predictions ?? [];
    const fallback: readonly PredictorPrediction[] =
      fromArray.length > 0
        ? fromArray
        : [
            {
              predictorId: "v1_basic",
              predictorName: "本命予想",
              slot: 1,
              aiEvaluationDaily: prediction.aiEvaluationDaily,
              aiEvaluationRealtime: prediction.aiEvaluationRealtime,
              betPayout:
                prediction.betPayout ?? {
                  daily: { betCount: 0, betCostYen: 0, payoutYen: 0, hit: false, actualSanrentan: null },
                  realtime: { betCount: 0, betCostYen: 0, payoutYen: 0, hit: false, actualSanrentan: null },
                },
              betHitStatus: prediction.betHitStatus ?? { dailyHit: false, realtimeHit: false },
            },
          ];
    return fallback;
  })().map((pp) => (
    <section class="mb-6">
      {/* スタート予想・1マーク予想を各予想者カード内に小さく横並びで表示する。
           スタート予想は全予想者共通で全国平均ST。1マーク予想は予想者ごとの
           AI 評価 (realtime 優先) を採用するため図が異なる。
           モーター予想 (slot=4, 現行) は本命予想 (slot=1) の motor を motor4 に置き換えた構成。
           退役済み: モーター評価変更予想 (slot=2, motor→motor2rate) / 展開予想 (slot=3, +展開優位pt)。
           過去日ページには退役予想者も残るため slot=2/3 の分岐も維持する。 */}
      <PredictorCard
        prediction={pp}
        racers={prediction.racers}
        startPrediction={
          pp.slot === 1 || pp.slot === 2 || pp.slot === 3 || pp.slot === 4
            ? prediction.startPrediction
            : undefined
        }
        oneMarkAiEvaluation={
          pp.slot === 1
            ? prediction.aiEvaluation
            : pp.slot === 2 || pp.slot === 3 || pp.slot === 4
              ? (pp.aiEvaluationRealtime ?? pp.aiEvaluationDaily)
              : undefined
        }
        recipeNote={
          pp.predictorId === "v4_motor"
            ? "本命予想の5成分のうち、モーターpt をエキスパート評価でチューニングしたモーター能力指数に置き換えた構成です。"
            : pp.predictorId === "v2_tenkai"
              ? "本命予想の5成分のうち、モーターpt を公式モーター2連対率pt（M2連率）に置き換えた構成です。"
              : pp.predictorId === "v3_tenkai"
                ? "本命予想の5成分に展開優位pt（進入コースと枠番デフォルトコースの勝率差）を加えた6成分の構成です。"
                : undefined
        }
      />
    </section>
  ))}

  {/* 直前情報（締切5分前の展示・気象スナップショット）。
       previews/tkz / previews/sui が未取得のレースでは prediction.preview が無いので非表示。 */}
  {prediction.preview &&
    (prediction.preview.boats.length > 0 ||
      prediction.preview.weather ||
      prediction.preview.originalExhibition) && (
      <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
        <h2 class="font-bold text-lg mb-3">直前情報</h2>
        <RacePreviewSection preview={prediction.preview} />
      </section>
    )}

  {/* 出走表 */}
  {prediction.racers.length > 0 && (
    <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
      <h2 class="font-bold text-lg mb-3">出走表</h2>
      <RacerTable racers={prediction.racers} />
    </section>
  )}

  {/* 近況5節（全国・当地）。programs/recent_national / recent_local が未取得のレースでは非表示。 */}
  {prediction.recentForm && prediction.recentForm.boats.length > 0 && (
    <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
      <h2 class="font-bold text-lg mb-3">近況5節</h2>
      <RecentFormSection recentForm={prediction.recentForm} />
    </section>
  )}

  <div class="text-center mt-6">
    <a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← トップページに戻る</a>
  </div>
</BaseLayout>
