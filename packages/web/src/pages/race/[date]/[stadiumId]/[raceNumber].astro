---
import type { RacePrediction } from "@fun-site/shared";
import { getRaceGradeBadge, getStadiumById, parseRaceCode } from "@fun-site/shared";
import AiEvaluationChart from "../../../../components/AiEvaluationChart.astro";
import BettingPicks from "../../../../components/BettingPicks.astro";
import OneMarkPredictionDiagram from "../../../../components/OneMarkPredictionDiagram.astro";
import RacerTable from "../../../../components/RacerTable.astro";
import RaceResultSection from "../../../../components/RaceResultSection.astro";
import StartPredictionDiagram from "../../../../components/StartPredictionDiagram.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { loadAvailableDates, loadPredictions } from "../../../../lib/data";

/** レース番号リンクバー用の各レースのメタ情報 */
type RaceNavItem = {
  raceNumber: number;
  raceName: string;
  votingDeadline: string;
  isConfirmed: boolean;
  /** 当日買い目が的中したか（確定済みかつ当日買い目フォーメーションが結果と一致） */
  dailyHit: boolean;
  /** 直前買い目が的中したか（確定済みかつ直前買い目フォーメーションが結果と一致） */
  realtimeHit: boolean;
};

export async function getStaticPaths() {
  const dates = await loadAvailableDates();
  const paths = [];

  for (const date of dates) {
    const predictions = await loadPredictions(date);
    // (date, stadiumId) ごとにレースメタ情報を集約
    const racesByStadium = new Map<string, RaceNavItem[]>();
    for (const prediction of predictions) {
      const parsed = parseRaceCode(prediction.raceCode);
      const list = racesByStadium.get(parsed.stadiumId) ?? [];
      // 確定判定: realtime 結果がセットされていれば確定。
      // ただし結果 CSV が未取得でも votingDeadline が "確定" になっているケースがあるため、
      // 文字列も併用判定する (上流 CSV の `電話投票締切予定` 列は確定後に "確定" に置き換わる)。
      const isConfirmed =
        prediction.raceResult !== undefined || prediction.votingDeadline === "確定";
      list.push({
        raceNumber: prediction.raceNumber,
        raceName: prediction.raceName ?? "",
        votingDeadline: prediction.votingDeadline ?? "",
        isConfirmed,
        dailyHit: prediction.betHitStatus?.dailyHit ?? false,
        realtimeHit: prediction.betHitStatus?.realtimeHit ?? false,
      });
      racesByStadium.set(parsed.stadiumId, list);
    }
    for (const prediction of predictions) {
      const parsed = parseRaceCode(prediction.raceCode);
      const stadiumRaces = [
        ...(racesByStadium.get(parsed.stadiumId) ?? []),
      ].sort((a, b) => a.raceNumber - b.raceNumber);
      paths.push({
        params: {
          date: parsed.date,
          stadiumId: parsed.stadiumId,
          raceNumber: String(prediction.raceNumber),
        },
        props: { prediction, stadiumRaces },
      });
    }
  }

  return paths;
}

interface Props {
  prediction: RacePrediction;
  stadiumRaces: RaceNavItem[];
}

const { prediction, stadiumRaces } = Astro.props;
const stadium = getStadiumById(prediction.stadiumId);
const stadiumName = stadium?.name ?? prediction.stadiumName;
const title = `${stadiumName} ${prediction.raceNumber}R - ${prediction.raceName || "スタート予想"}`;
const raceByNumber = new Map(stadiumRaces.map((r) => [r.raceNumber, r]));
const headerGradeBadge = getRaceGradeBadge(prediction.grade ?? "");
---

<BaseLayout title={title}>
  {/* パンくず */}
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">トップ</a>
    <span class="mx-1">/</span>
    <a href={`/stadium/${prediction.stadiumId}/`} class="hover:text-blue-600">{stadiumName}</a>
    <span class="mx-1">/</span>
    <span>{prediction.raceNumber}R</span>
  </nav>

  {/* レース番号リンク (1R-12R) */}
  <nav class="bg-white rounded-lg shadow-sm p-2 mb-4 overflow-x-auto" aria-label="レース番号">
    <ul class="flex gap-1 min-w-max">
      {Array.from({ length: 12 }, (_, i) => i + 1).map((n) => {
        const isCurrent = n === prediction.raceNumber;
        const meta = raceByNumber.get(n);
        const isAvailable = meta !== undefined;
        const isConfirmed = meta?.isConfirmed ?? false;
        const dailyHit = meta?.dailyHit ?? false;
        const realtimeHit = meta?.realtimeHit ?? false;
        const hasAnyHit = dailyHit || realtimeHit;

        // 状態別のスタイル: 背景色そのもので識別
        // 現在     → 青ベタ (白文字)
        // 開催予定 → 青系 (薄青背景 + 青ボーダー + 青文字)
        // 確定済み → 緑系 (薄緑背景 + 緑ボーダー + 緑文字)
        // 非開催   → 灰色ベタ (淡色文字)
        const tileBase =
          "flex flex-col items-center justify-between w-[4.75rem] min-h-[4.75rem] px-1 py-1.5 rounded-md select-none border-2";
        let tileClass = "";
        if (isCurrent) {
          tileClass = `${tileBase} bg-blue-600 text-white border-blue-700 shadow-sm`;
        } else if (!isAvailable) {
          tileClass = `${tileBase} bg-gray-100 text-gray-400 border-gray-200 cursor-not-allowed`;
        } else if (isConfirmed) {
          tileClass = `${tileBase} bg-emerald-50 text-emerald-900 border-emerald-300 hover:bg-emerald-100`;
        } else {
          tileClass = `${tileBase} bg-sky-50 text-sky-900 border-sky-300 hover:bg-sky-100`;
        }

        // 中身: レース番号 / レース名 / 締切 or 確定
        const inner = (
          <>
            <span class="text-sm font-bold leading-none tabular-nums">{n}R</span>
            <span class={`block text-[10px] leading-tight text-center mt-1 truncate max-w-full ${
              isCurrent
                ? "text-blue-100"
                : !isAvailable
                  ? "text-gray-400"
                  : isConfirmed
                    ? "text-emerald-700"
                    : "text-sky-700"
            }`}>
              {meta?.raceName || (isAvailable ? "—" : "未開催")}
            </span>
            {isAvailable ? (
              isConfirmed ? (
                <span class="mt-1 inline-flex items-center gap-0.5">
                  <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none ${
                    isCurrent ? "bg-white/25 text-white" : "bg-emerald-600 text-white"
                  }`}>
                    確定
                  </span>
                  {/* 当日買い目的中 → 🎯 (amber)、直前買い目的中 → 🔥 (cyan)。両方的中時は両方表示。 */}
                  {dailyHit && (
                    <span
                      class="inline-block text-[12px] leading-none"
                      title="当日買い目が的中"
                      aria-label="当日買い目が的中"
                    >
                      🎯
                    </span>
                  )}
                  {realtimeHit && (
                    <span
                      class="inline-block text-[12px] leading-none"
                      title="直前買い目が的中"
                      aria-label="直前買い目が的中"
                    >
                      🔥
                    </span>
                  )}
                </span>
              ) : (
                <span class={`mt-1 inline-block px-1 py-0.5 rounded text-[10px] font-mono leading-none tabular-nums ${
                  isCurrent ? "bg-white/15 text-white" : "bg-white text-sky-800 border border-sky-200"
                }`}>
                  {meta?.votingDeadline ? meta.votingDeadline : "—"}
                </span>
              )
            ) : (
              <span class="mt-1 text-[10px] leading-none">—</span>
            )}
          </>
        );

        if (isCurrent) {
          return (
            <li>
              <span class={tileClass} aria-current="page">
                {inner}
              </span>
            </li>
          );
        }
        if (isAvailable) {
          return (
            <li>
              <a
                href={`/race/${prediction.raceDate}/${prediction.stadiumId}/${n}/`}
                class={tileClass}
                aria-label={`${n}R ${meta?.raceName ?? ""}${
                  isConfirmed ? " 確定" : meta?.votingDeadline ? ` 締切 ${meta.votingDeadline}` : ""
                }${hasAnyHit ? ` (${[dailyHit ? "当日買い目的中" : "", realtimeHit ? "直前買い目的中" : ""].filter(Boolean).join(" / ")})` : ""}`}
              >
                {inner}
              </a>
            </li>
          );
        }
        return (
          <li>
            <span class={tileClass}>{inner}</span>
          </li>
        );
      })}
    </ul>
  </nav>

  {/* ヘッダ */}
  <header class="mb-6">
    <h1 class="text-2xl font-bold flex items-baseline gap-2 flex-wrap">
      <span>{stadiumName}</span>
      <span class="text-blue-600">{prediction.raceNumber}R</span>
      {prediction.raceName && (
        <span class="text-base text-gray-700 font-normal">{prediction.raceName}</span>
      )}
    </h1>
    <p class="text-sm text-gray-500 mt-1 flex flex-wrap items-center gap-x-2 gap-y-1">
      <span>{prediction.raceDate}</span>
      {headerGradeBadge && (
        <span
          class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none ${headerGradeBadge.tailwindClass}`}
          aria-label={`グレード ${headerGradeBadge.label}`}
        >
          {headerGradeBadge.label}
        </span>
      )}
      {prediction.raceTitle && <span>{prediction.raceTitle}</span>}
      {prediction.dayLabel && <span>{prediction.dayLabel}</span>}
      {prediction.votingDeadline && (
        <span>{prediction.votingDeadline === "確定" ? "確定" : `締切 ${prediction.votingDeadline}`}</span>
      )}
    </p>
  </header>

  {/* レース結果（確定済みのみ表示） */}
  {prediction.raceResult && (
    <section class="bg-white rounded-lg shadow-sm p-4 mb-6 border-l-4 border-blue-500">
      <h2 class="font-bold text-lg mb-3">レース結果</h2>
      <RaceResultSection
        result={prediction.raceResult}
        hitStatus={prediction.betHitStatus}
      />
    </section>
  )}

  {/* 買い目（当日・直前を併記） */}
  <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
    <h2 class="font-bold text-lg mb-3">買い目</h2>
    <BettingPicks
      racers={prediction.racers}
      aiEvaluationDaily={prediction.aiEvaluationDaily}
      aiEvaluationRealtime={prediction.aiEvaluationRealtime}
      aiEvaluation={prediction.aiEvaluation}
      hitStatus={prediction.betHitStatus}
    />
  </section>

  {/* スタート予想 */}
  <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
    <h2 class="font-bold text-lg mb-3">スタート予想</h2>
    <StartPredictionDiagram start={prediction.startPrediction} />
  </section>

  {/* 1マーク予想 */}
  <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
    <h2 class="font-bold text-lg mb-3">1マーク予想</h2>
    <OneMarkPredictionDiagram
      racers={prediction.racers}
      aiEvaluation={prediction.aiEvaluation}
    />
  </section>

  {/* AIによる総合評価 */}
  <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
    <h2 class="font-bold text-lg mb-3">AIによる総合評価</h2>
    <AiEvaluationChart evaluation={prediction.aiEvaluation} />
  </section>

  {/* 出走表 */}
  {prediction.racers.length > 0 && (
    <section class="bg-white rounded-lg shadow-sm p-4 mb-6">
      <h2 class="font-bold text-lg mb-3">出走表</h2>
      <RacerTable racers={prediction.racers} />
    </section>
  )}

  <div class="text-center mt-6">
    <a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← トップページに戻る</a>
  </div>
</BaseLayout>
