---
import { getStadiumById } from "@fun-site/shared";
import RaceCard from "../../components/RaceCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAvailableDates, loadHistoricalDates, loadPredictions } from "../../lib/data";

export async function getStaticPaths() {
  // 当日分のみページ生成 (過去ページは GCS 残置を利用)。
  const dates = await loadAvailableDates();
  // 「他の日付」セクション用に、これまで公開された全日付を渡す。
  const historicalDates = await loadHistoricalDates();
  const paths = [];

  for (const date of dates) {
    const predictions = await loadPredictions(date);
    paths.push({
      params: { date },
      props: { predictions, date, historicalDates },
    });
  }

  return paths;
}

interface Props {
  predictions: Awaited<ReturnType<typeof loadPredictions>>;
  date: string;
  historicalDates: string[];
}

const { predictions, date, historicalDates } = Astro.props;

const stadiumGroups = new Map<string, typeof predictions>();
for (const prediction of predictions) {
  const key = prediction.stadiumId;
  const group = stadiumGroups.get(key) ?? [];
  group.push(prediction);
  stadiumGroups.set(key, group);
}

// 「他の日付」: 同月の他の日付を優先し、不足分は前月から補完。最大 14 件。
const currentMonth = date.slice(0, 7);
const sameMonthOthers = historicalDates.filter(
  (d) => d !== date && d.startsWith(currentMonth),
);
const prevMonthOthers = historicalDates.filter(
  (d) => d !== date && !d.startsWith(currentMonth),
);
const OTHER_DATES_LIMIT = 14;
const otherDates = [...sameMonthOthers, ...prevMonthOthers].slice(0, OTHER_DATES_LIMIT);
---

<BaseLayout title={`${date} の予想 - アーカイブ`}>
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">トップ</a>
    <span class="mx-1">/</span>
    <a href="/archive/" class="hover:text-blue-600">アーカイブ</a>
    <span class="mx-1">/</span>
    <span>{date}</span>
  </nav>

  <h1 class="text-2xl font-bold mb-4">{date} の予想</h1>

  {predictions.length === 0 ? (
    <div class="bg-white rounded-lg shadow-sm p-8 text-center text-gray-500">
      <p>この日のデータはありません</p>
    </div>
  ) : (
    <div class="space-y-8">
      {[...stadiumGroups.entries()].map(([stadiumId, races]) => {
        const stadium = getStadiumById(stadiumId);
        const sortedRaces = [...races].sort((a, b) => a.raceNumber - b.raceNumber);
        return (
          <section>
            <h2 class="text-lg font-bold mb-3 flex items-center gap-2">
              <span class="w-1 h-6 bg-blue-600 rounded-full" />
              {stadium?.name ?? stadiumId}
              {stadium && (
                <span class="text-sm text-gray-400 font-normal">{stadium.prefecture}</span>
              )}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {sortedRaces.map((prediction) => (
                <RaceCard prediction={prediction} />
              ))}
            </div>
          </section>
        );
      })}
    </div>
  )}

  {otherDates.length > 0 && (
    <section class="mt-10">
      <div class="flex items-baseline justify-between mb-3">
        <h2 class="font-bold">他の日付</h2>
        <a href="/archive/" class="text-sm text-blue-600 hover:text-blue-800">
          すべてのアーカイブ →
        </a>
      </div>
      <div class="flex flex-wrap gap-2">
        {otherDates.map((d) => (
          <a
            href={`/archive/${d}/`}
            class="text-sm px-3 py-1.5 bg-white border border-gray-200 rounded hover:bg-blue-50 hover:border-blue-300 transition-colors"
          >
            {d}
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="mt-8 text-center">
    <a href="/" class="text-blue-600 hover:text-blue-800 text-sm">
      ← トップページに戻る
    </a>
  </div>
</BaseLayout>
