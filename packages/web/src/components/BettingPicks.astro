---
import type { AiEvaluation, BetHitStatus, RaceRacer } from "@fun-site/shared";
import {
  BOAT_COLORS,
  computeBettingPicks,
  computeOneMarkDistances,
  isValidBoatNumber,
} from "@fun-site/shared";

interface Props {
  racers: readonly RaceRacer[];
  /** 朝バッチ時点の AI 評価 (= 当日買い目の根拠)。無ければ当日買い目は表示されない。 */
  aiEvaluationDaily?: AiEvaluation;
  /** 直前情報反映後の AI 評価 (= 直前買い目の根拠)。無ければ直前買い目は「未取得」と表示する。 */
  aiEvaluationRealtime?: AiEvaluation;
  /** 後方互換: いずれの個別評価も渡されていない場合のフォールバック。
   *  state によって当日買い目 / 直前買い目 を切り替える。 */
  aiEvaluation?: AiEvaluation;
  /** 結果確定後の的中状況。未指定なら的中バッジは表示しない。 */
  hitStatus?: BetHitStatus;
  /** 見出しの先頭に付ける予想者名（例: "A君予想"）。未指定なら付けない。 */
  predictorName?: string;
}

const {
  racers,
  aiEvaluationDaily,
  aiEvaluationRealtime,
  aiEvaluation,
  hitStatus,
  predictorName,
} = Astro.props;

/** 見出し: "{shortName}当日買い目" / "{shortName}直前買い目"。
 *  predictorName 末尾の「予想」サフィックスは除去する ("A君予想" → "A君")。
 *  predictorName 省略時はプレフィクス無し。 */
const headingPrefix = predictorName ? predictorName.replace(/予想$/, "") : "";

// 後方互換: aiEvaluation 単体が渡された場合は state を見て daily / realtime のどちらかに振り分ける
const dailyEval =
  aiEvaluationDaily ??
  (aiEvaluation && aiEvaluation.state === "daily" ? aiEvaluation : undefined);
const realtimeEval =
  aiEvaluationRealtime ??
  (aiEvaluation && aiEvaluation.state === "realtime" ? aiEvaluation : undefined);

type Group = { readonly label: string; readonly boats: readonly number[] };

const buildGroups = (evaluation: AiEvaluation): Group[] => {
  const distanceEntries = computeOneMarkDistances(racers, evaluation);
  const picks = computeBettingPicks(distanceEntries);
  return [
    { label: "1着", boats: picks.first },
    { label: "2着", boats: picks.second },
    { label: "3着", boats: picks.third },
  ];
};

type SectionKind = "daily" | "realtime";

const sections: {
  readonly kind: SectionKind;
  readonly heading: string;
  readonly groups: Group[] | null;
}[] = [
  {
    kind: "daily",
    heading: `${headingPrefix}当日買い目`,
    groups: dailyEval ? buildGroups(dailyEval) : null,
  },
  {
    kind: "realtime",
    heading: `${headingPrefix}直前買い目`,
    groups: realtimeEval ? buildGroups(realtimeEval) : null,
  },
];

const isSectionHit = (kind: SectionKind): boolean => {
  if (!hitStatus) return false;
  return kind === "daily" ? hitStatus.dailyHit : hitStatus.realtimeHit;
};

/** 当日 = 🎯 + amber, 直前 = 🔥 + cyan で識別する */
const hitBadgeClass = (kind: SectionKind): string =>
  kind === "daily"
    ? "inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-bold bg-amber-100 text-amber-800 border border-amber-300"
    : "inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-bold bg-cyan-100 text-cyan-800 border border-cyan-300";

const hitBadgeIcon = (kind: SectionKind): string => (kind === "daily" ? "🎯" : "🔥");

const boatBoxStyle = (boatNumber: number): string => {
  const color = isValidBoatNumber(boatNumber) ? BOAT_COLORS[boatNumber] : undefined;
  const bg = color?.hex ?? "#999";
  const fg = color?.textHex ?? "#fff";
  // 1号艇 (白) は視認性確保のため細いボーダーを付ける
  const border = boatNumber === 1 ? " border: 1px solid #cbd5e1;" : "";
  return `background-color: ${bg}; color: ${fg};${border}`;
};
---

<div class="space-y-4">
  {sections.map((section) => (
    <div>
      <h3 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-2">
        <span>{section.heading}</span>
        {isSectionHit(section.kind) && (
          <span class={hitBadgeClass(section.kind)} aria-label={`${section.heading}が的中`}>
            <span aria-hidden="true">{hitBadgeIcon(section.kind)}</span>
            <span>的中</span>
          </span>
        )}
      </h3>
      {section.groups === null ? (
        <p class="text-xs text-gray-400">
          {section.kind === "realtime"
            ? "直前情報がまだ反映されていません。"
            : "当日の AI 評価が取得できていません。"}
        </p>
      ) : (
        <div class="flex flex-wrap items-center gap-2">
          {section.groups.map((group, gi) => (
            <>
              {gi > 0 && (
                <span class="text-gray-500 text-xl font-bold mx-0.5" aria-hidden="true">−</span>
              )}
              <div
                class="flex items-center gap-1.5"
                aria-label={`${section.heading} ${group.label}候補`}
              >
                {group.boats.length === 0 ? (
                  <span class="text-xs text-gray-400">該当なし</span>
                ) : (
                  group.boats.map((bn) => (
                    <span
                      class="inline-flex items-center justify-center w-8 h-8 rounded-md text-base font-bold"
                      style={boatBoxStyle(bn)}
                      title={`${section.heading} ${group.label}候補: ${bn}号艇`}
                    >
                      {bn}
                    </span>
                  ))
                )}
              </div>
            </>
          ))}
        </div>
      )}
    </div>
  ))}
</div>
<p class="text-xs text-gray-500 mt-3">
  1マーク予想の走行距離を基準に、各着順の上位艇から ±0.10 以内の艇を候補としています（三連単フォーメーションの目安）。
  「当日買い目」は朝バッチ時点（直前情報反映前）、「直前買い目」は直前情報反映後の AI 評価に基づきます。
</p>
