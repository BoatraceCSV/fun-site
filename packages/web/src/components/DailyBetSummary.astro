---
import type {
  BetPayoutResult,
  DailyBetPayoutAggregate,
  PredictorSpec,
  RacePrediction,
} from "@fun-site/shared";
import { activePredictors, aggregateDailyBetPayout, isSettledResult } from "@fun-site/shared";

interface Props {
  /** 当日の全レース予想。確定済みかつフォーメーションが計算できたレースだけが集計対象に入る。 */
  predictions: readonly RacePrediction[];
}

const { predictions } = Astro.props;

/** "本命予想" → "本命"。 予想 サフィックスを剥がしてプレフィクスに使う。 */
const shortName = (displayName: string): string => displayName.replace(/予想$/, "");

const formatYen = (n: number): string => `¥${n.toLocaleString("ja-JP")}`;
const formatPercent = (n: number): string => `${(n * 100).toFixed(1)}%`;

/**
 * 全レース予想を走査し、指定 predictor の **直前 (realtime)** 買い目の
 * `BetPayoutResult` を集める。新スキーマ (`predictions[]`) を優先し、
 * 旧 JSON で primary predictor かつ predictions[] が無い場合のみ
 * legacy `prediction.betPayout.realtime` にフォールバックする。
 */
const collectRealtimeResults = (
  preds: readonly RacePrediction[],
  predictorId: string,
  isPrimary: boolean,
): BetPayoutResult[] => {
  const out: BetPayoutResult[] = [];
  for (const p of preds) {
    // 未確定レース（結果未着・中止・不成立）は母数・購入額から除外する。
    if (!isSettledResult(p.raceResult)) continue;
    const fromArray = p.predictions?.find((pp) => pp.predictorId === predictorId);
    if (fromArray) {
      out.push(fromArray.betPayout.realtime);
      continue;
    }
    // 旧 JSON フォールバック (primary predictor ぶんのみ)。
    if (isPrimary && p.betPayout) {
      out.push(p.betPayout.realtime);
    }
  }
  return out;
};

type Card = {
  readonly key: string;
  readonly predictor: PredictorSpec;
  readonly heading: string;
  readonly accentClass: string;
  readonly agg: DailyBetPayoutAggregate;
};

const cards: readonly Card[] = activePredictors().map((predictor, idx) => {
  const isPrimary = idx === 0;
  const prefix = shortName(predictor.displayName);
  const results = collectRealtimeResults(predictions, predictor.id, isPrimary);
  return {
    key: predictor.id,
    predictor,
    heading: `${prefix}直前買い目`,
    accentClass: "border-cyan-400 bg-cyan-50",
    agg: aggregateDailyBetPayout(results),
  };
});

const hasAny = cards.some((c) => c.agg.settledRaceCount > 0);
---

{hasAny && (
  <section class="mb-6">
    <h2 class="text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
      <span class="w-1 h-4 bg-blue-600 rounded-full" />
      本日の AI 3連単 成績
    </h2>
    <p class="text-xs text-gray-500 mb-3">
      直前情報反映後の買い目フォーメーション全組合せを 1 点 ¥100 で 3連単 として買った場合の集計（締切済みレースのみ・予想者別）。
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {cards.map((c) => {
        const { agg } = c;
        if (agg.settledRaceCount === 0) return null;
        return (
          <div class={`rounded-lg border-l-4 p-4 ${c.accentClass}`}>
            <p class="text-sm font-bold text-gray-800 mb-2">{c.heading}</p>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div>
                <p class="text-xs text-gray-500">的中率</p>
                <p class="text-lg font-bold text-gray-900">
                  {formatPercent(agg.hitRate)}
                  <span class="text-xs font-normal text-gray-500 ml-1">
                    ({agg.hitCount}/{agg.settledRaceCount})
                  </span>
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-500">回収率</p>
                <p class={`text-lg font-bold ${agg.recoveryRate >= 1 ? "text-green-700" : "text-gray-900"}`}>
                  {formatPercent(agg.recoveryRate)}
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-500">賭け金合計</p>
                <p class="text-sm text-gray-700">{formatYen(agg.totalBetCostYen)}</p>
              </div>
              <div>
                <p class="text-xs text-gray-500">払戻合計</p>
                <p class={`text-sm font-medium ${agg.totalPayoutYen > 0 ? "text-green-700" : "text-gray-500"}`}>
                  {formatYen(agg.totalPayoutYen)}
                </p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>
)}
