---
import type { RaceRacer } from "@fun-site/shared";
import { BOAT_COLORS, isValidBoatNumber } from "@fun-site/shared";
import SessionResultsGrid from "./SessionResultsGrid.astro";

interface Props {
  racers: readonly RaceRacer[];
}

const { racers } = Astro.props;
const sorted = [...racers].sort((a, b) => a.boatNumber - b.boatNumber);

const rankColor = (rank: string): string => {
  if (rank === "A1") return "text-red-600";
  if (rank === "A2") return "text-orange-500";
  if (rank === "B1") return "text-gray-700";
  return "text-gray-500";
};

/** いずれかの選手に節間成績があるか（ある場合のみ展開行を出す） */
const hasAnySessionResults = sorted.some((r) =>
  r.sessionResults.some((s) => s.rank !== "" || s.race > 0),
);
const COL_SPAN = 8;
---

<div class="overflow-x-auto">
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="bg-gray-100 text-gray-600">
        <th scope="col" class="px-2 py-2 text-left">艇</th>
        <th scope="col" class="px-2 py-2 text-left">選手</th>
        <th scope="col" class="px-2 py-2 text-center">級別</th>
        <th scope="col" class="px-2 py-2 text-right hidden sm:table-cell">平均ST</th>
        <th scope="col" class="px-2 py-2 text-right">全国 勝率/2連/3連</th>
        <th scope="col" class="px-2 py-2 text-right hidden sm:table-cell">当地 勝率/2連/3連</th>
        <th scope="col" class="px-2 py-2 text-right hidden md:table-cell">モーター 2連/3連</th>
        <th scope="col" class="px-2 py-2 text-right hidden lg:table-cell">ボート 2連/3連</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map((racer) => {
        const color = isValidBoatNumber(racer.boatNumber)
          ? BOAT_COLORS[racer.boatNumber]
          : undefined;
        return (
          <>
            <tr class={`hover:bg-gray-50 ${hasAnySessionResults ? "" : "border-b border-gray-100"}`}>
              <td class="px-2 py-2 align-top">
                <span
                  class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold"
                  style={`background-color: ${color?.hex ?? "#999"}; color: ${color?.textHex ?? "#fff"};${racer.boatNumber === 1 ? " border: 1px solid #cbd5e1;" : ""}`}
                >
                  {racer.boatNumber}
                </span>
              </td>
              <td class="px-2 py-2">
                <div class="font-medium flex items-center gap-1 flex-wrap">
                  <span>{racer.racerName}</span>
                  {racer.flyingCount > 0 && (
                    <span
                      class="inline-block px-1 py-0.5 rounded text-[10px] font-bold leading-none bg-red-100 text-red-700"
                      title={`フライング ${racer.flyingCount} 本`}
                    >
                      F{racer.flyingCount}
                    </span>
                  )}
                  {racer.lateCount > 0 && (
                    <span
                      class="inline-block px-1 py-0.5 rounded text-[10px] font-bold leading-none bg-amber-100 text-amber-800"
                      title={`出遅れ ${racer.lateCount} 本`}
                    >
                      L{racer.lateCount}
                    </span>
                  )}
                  {racer.prizeExcluded && (
                    <span
                      class="inline-block px-1 py-0.5 rounded text-[10px] font-bold leading-none bg-gray-200 text-gray-600"
                      title="賞金除外（補欠出走等）"
                    >
                      賞除
                    </span>
                  )}
                </div>
                <div class="text-xs text-gray-500">
                  {racer.age > 0 && <span>{racer.age}歳</span>}
                  {racer.branch && <span class="ml-1">{racer.branch}</span>}
                  {racer.hometown && racer.hometown !== racer.branch && (
                    <span class="ml-1 text-gray-400">/ {racer.hometown}</span>
                  )}
                </div>
              </td>
              <td class="px-2 py-2 text-center align-top">
                <span class={`text-xs font-semibold ${rankColor(racer.classGrade)}`}>
                  {racer.classGrade}
                </span>
              </td>
              <td class="px-2 py-2 text-right font-mono text-xs hidden sm:table-cell align-top">
                {racer.nationalAvgST > 0 ? racer.nationalAvgST.toFixed(2) : "—"}
              </td>
              <td class="px-2 py-2 text-right font-mono text-xs align-top">
                {racer.nationalWinRate.toFixed(2)}
                <span class="text-gray-400"> / </span>
                {racer.nationalTop2Rate.toFixed(1)}
                <span class="text-gray-400"> / </span>
                {racer.nationalTop3Rate.toFixed(1)}%
              </td>
              <td class="px-2 py-2 text-right font-mono text-xs hidden sm:table-cell align-top">
                {racer.localWinRate.toFixed(2)}
                <span class="text-gray-400"> / </span>
                {racer.localTop2Rate.toFixed(1)}
                <span class="text-gray-400"> / </span>
                {racer.localTop3Rate.toFixed(1)}%
              </td>
              <td class="px-2 py-2 text-right font-mono text-xs hidden md:table-cell align-top">
                #{racer.motorNumber}
                <span class="text-gray-400"> / </span>
                {racer.motorTop2Rate.toFixed(1)}
                <span class="text-gray-400"> / </span>
                {racer.motorTop3Rate.toFixed(1)}%
              </td>
              <td class="px-2 py-2 text-right font-mono text-xs hidden lg:table-cell align-top">
                #{racer.boatBodyNumber}
                <span class="text-gray-400"> / </span>
                {racer.boatTop2Rate.toFixed(1)}
                <span class="text-gray-400"> / </span>
                {racer.boatTop3Rate.toFixed(1)}%
              </td>
            </tr>
            {hasAnySessionResults && (
              <tr class="border-b border-gray-100">
                <td class="px-2 pb-2 pt-0" colspan={COL_SPAN}>
                  <SessionResultsGrid slots={racer.sessionResults} />
                </td>
              </tr>
            )}
          </>
        );
      })}
    </tbody>
  </table>
</div>
