---
import type { RacePrediction, SeriesBetPayoutAggregate } from "@fun-site/shared";
import { getRaceGradeBadge, getStadiumById } from "@fun-site/shared";

interface Props {
  prediction: RacePrediction;
  /**
   * 当該会場の節集計 (直前買い目戦略)。3 行目の今節成績表示に使う。
   * 渡されない or null の場合は「節成績データなし」表示にフォールバック。
   * `_meta/series-summary.json` の `byStadium[stadiumId]` を呼び出し側でルックアップして渡す。
   */
  seriesAggregate?: SeriesBetPayoutAggregate | null;
}

const { prediction, seriesAggregate } = Astro.props;
const stadium = getStadiumById(prediction.stadiumId);
const stadiumName = stadium?.name ?? prediction.stadiumName;
const raceUrl = `/race/${prediction.raceDate}/${prediction.stadiumId}/${prediction.raceNumber}`;

// 確定済み判定 (詳細ページの判定と揃える)
const isConfirmed =
  prediction.raceResult !== undefined || prediction.votingDeadline === "確定";

// 2 行目に並べるサブタイトル: 節タイトル / 日次 / レース名 を空文字を除いて連結
const subtitleParts = [
  prediction.raceTitle,
  prediction.dayLabel,
  prediction.raceName,
].filter((s) => typeof s === "string" && s.length > 0);
const subtitle = subtitleParts.join(" ");

// 2 行目先頭のグレードバッジ。一般戦 (IP) や未設定の場合は null。
const gradeBadge = getRaceGradeBadge(prediction.grade ?? "");

// 3 行目: 今節成績 (直前買い目戦略)。
// settledRaceCount === 0 (節初日でまだ確定 0 等) は「データなし」扱いにする。
const hasSeriesData =
  seriesAggregate != null && seriesAggregate.settledRaceCount > 0;

const formatPercent = (n: number): string => `${(n * 100).toFixed(1)}%`;
/** "2026-05-21" → "5/21" */
const shortDate = (d: string): string => {
  const parts = d.split("-");
  return `${Number(parts[1])}/${Number(parts[2])}`;
};
---

<a
  href={raceUrl}
  class="block bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-100 p-4"
>
  {/* 1行目: 会場 + レース番号 / 締切 or 確定 */}
  <div class="flex items-center justify-between mb-1.5">
    <h3 class="font-bold text-base">
      {stadiumName} <span class="text-blue-600">{prediction.raceNumber}R</span>
    </h3>
    {isConfirmed ? (
      <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none bg-emerald-600 text-white">
        確定
      </span>
    ) : prediction.votingDeadline ? (
      <span class="text-xs text-gray-500">締切 {prediction.votingDeadline}</span>
    ) : null}
  </div>

  {/* 2行目: [グレード] 節タイトル 何日目 レース名 */}
  {(subtitle || gradeBadge) && (
    <p
      class="text-xs text-gray-600 mb-2 truncate flex items-center gap-1.5"
      title={`${gradeBadge ? `${gradeBadge.label} ` : ""}${subtitle}`}
    >
      {gradeBadge && (
        <span
          class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold leading-none shrink-0 ${gradeBadge.tailwindClass}`}
          aria-label={`グレード ${gradeBadge.label}`}
        >
          {gradeBadge.label}
        </span>
      )}
      {subtitle && <span class="truncate">{subtitle}</span>}
    </p>
  )}

  {/* 3行目: 今節成績 (直前買い目戦略の的中率 / 回収率)。
       渡されない / データなしの場合は控えめなフォールバック表示。 */}
  {hasSeriesData ? (
    <div
      class="flex items-center gap-2 text-xs"
      aria-label={`今節成績 ${shortDate(seriesAggregate!.seriesStartDate)} 〜 ${shortDate(seriesAggregate!.seriesEndDate)}`}
    >
      <span class="text-gray-500 shrink-0">今節</span>
      <span class="text-gray-600 shrink-0 tabular-nums">
        {shortDate(seriesAggregate!.seriesStartDate)}〜{shortDate(seriesAggregate!.seriesEndDate)}
      </span>
      <span class="text-gray-300" aria-hidden="true">|</span>
      <span class="text-gray-700">
        的中 <span class="font-bold tabular-nums">{formatPercent(seriesAggregate!.hitRate)}</span>
        <span class="text-gray-400 text-[10px] ml-0.5 tabular-nums">
          ({seriesAggregate!.hitCount}/{seriesAggregate!.settledRaceCount})
        </span>
      </span>
      <span class="text-gray-300" aria-hidden="true">|</span>
      <span class={seriesAggregate!.recoveryRate >= 1 ? "text-green-700" : "text-gray-700"}>
        回収 <span class="font-bold tabular-nums">{formatPercent(seriesAggregate!.recoveryRate)}</span>
      </span>
    </div>
  ) : (
    <p class="text-xs text-gray-400">今節成績: 集計データなし</p>
  )}
</a>
