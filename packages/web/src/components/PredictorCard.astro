---
import type { AiEvaluation, PredictorPrediction, RaceRacer, StartPrediction } from "@fun-site/shared";
import AiEvaluationChart from "./AiEvaluationChart.astro";
import BetPayoutSummary from "./BetPayoutSummary.astro";
import BettingPicks from "./BettingPicks.astro";
import OneMarkPredictionDiagram from "./OneMarkPredictionDiagram.astro";
import StartPredictionDiagram from "./StartPredictionDiagram.astro";

interface Props {
  /** この予想者ぶんの予想内容 (1 予想者 / 1 レース)。 */
  prediction: PredictorPrediction;
  /** AI 評価バー / 1マーク予想で参照する出走表。 */
  racers: readonly RaceRacer[];
  /** 結果確定後の AI 評価チャートを表示するか。デフォルト true。 */
  showChart?: boolean;
  /**
   * スタート予想図。予想者非依存の共通情報 (全国平均ST + 進入コース) だが、
   * primary predictor (本命予想 / slot=1) のカード内にまとめて表示するため任意 prop で受け取る。
   * 渡された場合のみ 1マーク予想と横並びで描画する。
   */
  startPrediction?: StartPrediction;
  /**
   * 1マーク予想図で参照する AI 評価。この予想者の評価を渡す。
   * `startPrediction` と両方揃った場合のみ 2 図を横並び描画する。
   */
  oneMarkAiEvaluation?: AiEvaluation;
  /**
   * スタート予想図の ST 説明文の上書き。モーター評価変更予想のように ST を一律固定値で
   * 表示する場合に注記を差し替えるため `StartPredictionDiagram` へ転送する。
   */
  startNote?: string;
  /**
   * 予想者カード見出し直下に出す注記。本命予想からどの成分をどう変更したか等、
   * recipe の差分を読み手に説明するために使う (例: モーター評価変更予想)。
   * 未指定なら何も描画しない。
   */
  recipeNote?: string;
  /**
   * 1マーク予想の予測 ST に AI 推定 ST を使うか (v5_slit のカードで true)。
   * `OneMarkPredictionDiagram` へ転送する。
   */
  useOneMarkEstimatedST?: boolean;
}

const {
  prediction,
  racers,
  showChart = true,
  startPrediction,
  oneMarkAiEvaluation,
  startNote,
  recipeNote,
  useOneMarkEstimatedST = false,
} = Astro.props;

// チャート用の評価: realtime 優先、無ければ daily。両方無ければ表示しない。
const chartEval = prediction.aiEvaluationRealtime ?? prediction.aiEvaluationDaily;

// スタート予想・1マーク予想の両方が揃ったときだけカード内に横並び表示する。
const showDiagrams = startPrediction !== undefined && oneMarkAiEvaluation !== undefined;
---

<section
  class="rounded-lg border border-gray-200 bg-white shadow-sm overflow-hidden"
  aria-label={`${prediction.predictorName}の予想`}
  data-predictor-id={prediction.predictorId}
>
  <header class="px-4 py-2 bg-gradient-to-r from-indigo-50 to-white border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-base font-bold text-gray-800 flex items-center gap-2">
      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold">
        {prediction.slot}
      </span>
      <span>{prediction.predictorName}</span>
    </h2>
    <span class="text-[11px] text-gray-400 font-mono">{prediction.predictorId}</span>
  </header>

  {recipeNote && (
    <p class="px-4 py-2 bg-amber-50 border-b border-amber-100 text-[12px] leading-snug text-amber-900">
      {recipeNote}
    </p>
  )}

  <div class="p-4 space-y-4">
    {/* 買い目 */}
    <BettingPicks
      racers={racers}
      aiEvaluationDaily={prediction.aiEvaluationDaily}
      aiEvaluationRealtime={prediction.aiEvaluationRealtime}
      hitStatus={prediction.betHitStatus}
      predictorName={prediction.predictorName}
      predictorId={prediction.predictorId}
    />

    {/* 回収率 */}
    <div class="border-t border-gray-100 pt-3">
      <BetPayoutSummary
        summary={prediction.betPayout}
        predictorName={prediction.predictorName}
      />
    </div>

    {/* AI 評価のスタックバー (任意) */}
    {showChart && chartEval && (
      <div class="border-t border-gray-100 pt-3">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">AI 評価の内訳</h3>
        <AiEvaluationChart evaluation={chartEval} />
      </div>
    )}

    {/* スタート予想・1マーク予想 (primary predictor のカードにのみ表示)。
         小さく横並びに収めるため 2 カラムグリッドで描画する。 */}
    {showDiagrams && (
      <div class="border-t border-gray-100 pt-3">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <h3 class="text-sm font-semibold text-gray-700 mb-2">スタート予想</h3>
            <StartPredictionDiagram start={startPrediction!} stNote={startNote} />
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-700 mb-2">1マーク予想</h3>
            <OneMarkPredictionDiagram
              racers={racers}
              aiEvaluation={oneMarkAiEvaluation!}
              useEstimatedST={useOneMarkEstimatedST}
            />
          </div>
        </div>
      </div>
    )}
  </div>
</section>
