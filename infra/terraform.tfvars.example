# GCP Project
project_id   = "your-gcp-project-id"
project_name = "fun-site"
region       = "us-central1"

# Domain
domain_name = "example.com"

# Batch settings
# 09:00 JST に起動。BoatraceCSV の daily-sync.yml (08:30 JST 起動・~10 分) で
# 当日分の programs / race_cards / index が公開された直後に走らせる。
batch_schedule  = "0 9 * * *"
batch_timezone  = "Asia/Tokyo"
batch_cpu       = "2"
batch_memory    = "2Gi"
batch_timeout   = "1800s"
batch_max_retries = 1

# CDN
cdn_cache_ttl = 3600

# Storage
storage_lifecycle_age_days = 90

# Vertex AI
vertex_ai_location = "global"

# Monitoring
alert_notification_email = "your-email@example.com"

# Cloud Build (GitHub)
github_owner = "your-github-username"
github_repo  = "fun-site"
